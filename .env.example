# =============================================
# BUSINESS ASSISTANT — Environment Variables
# Copy to .env and fill in your values
# ALL services below have FREE tiers
# =============================================

# === Django ===
# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# === Database ===
# SQLite for local dev (default - zero setup)
DATABASE_URL=sqlite:///db.sqlite3

# For production PostgreSQL:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# === AI Models ===
# Gemini: https://aistudio.google.com (free, 1.5 Flash has 1M tokens/day)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Groq: https://console.groq.com (free tier, very fast)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter: https://openrouter.ai (free models available)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# === Search (optional) ===
# Brave Search: https://api.search.brave.com (free tier: 2000 queries/month)
BRAVE_SEARCH_API_KEY=your_brave_key_here

# === Redis (optional, for Celery) ===
# Upstash: https://upstash.com (free tier)
REDIS_URL=redis://localhost:6379/0

# === Timeouts (seconds) ===
GEMINI_TIMEOUT=15
GROQ_TIMEOUT=10
OPENROUTER_TIMEOUT=20
MAX_TOOL_ITERATIONS=6

# === Document Processing ===
MAX_UPLOAD_SIZE_MB=10
CHUNK_SIZE_CHARS=1500
MAX_CHUNKS_PER_DOC=20

# === Security Settings (Production) ===
# Enable these for production deployment
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# === Email Configuration ===
# For development: use console backend (prints to terminal)
# For production: use smtp backend with proper credentials
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Business Assistant <noreply@localhost>
