# =============================================
# BUSINESS ASSISTANT — Environment Variables
# Copy to .env and fill in your values
# ALL services below have FREE tiers
# =============================================

# === Django ===
SECRET_KEY=your-secret-key-here-generate-with-python-c-"import secrets; print(secrets.token_hex(50))"
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# === Database ===
# Supabase free tier: https://supabase.com (free PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === AI Models ===
# Gemini: https://aistudio.google.com (free, 1.5 Flash has 1M tokens/day)
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-1.5-flash-latest

# Groq: https://console.groq.com (free tier, very fast)
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama3-8b-8192

# OpenRouter: https://openrouter.ai (free models available: mistral, llama, etc.)
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# === Search (optional) ===
# Brave Search: https://api.search.brave.com (free tier: 2000 queries/month)
BRAVE_SEARCH_API_KEY=your_brave_key
# DuckDuckGo used as fallback (no key needed)

# === Redis (optional, for Celery) ===
# Upstash: https://upstash.com (free tier)
REDIS_URL=redis://localhost:6379/0

# === Timeouts (seconds) ===
GEMINI_TIMEOUT=15
GROQ_TIMEOUT=10
OPENROUTER_TIMEOUT=20
MAX_TOOL_ITERATIONS=6

# === Document Processing ===
MAX_UPLOAD_SIZE_MB=10
CHUNK_SIZE_CHARS=1500
MAX_CHUNKS_PER_DOC=20
