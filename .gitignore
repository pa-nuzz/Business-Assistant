# =============================================
# AEIOU AI — Production Gitignore
# =============================================

# === ENVIRONMENT VARIABLES (CRITICAL) ===
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.backup

# === PYTHON / DJANGO ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual Environments (NEVER commit these)
venv/
env/
ENV/
.venv/
.venv.bak/

# Django specific
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
db.sqlite3.backup
*.dump
*.sql
media/
staticfiles/
static/

# === FRONTEND (NEXT.JS) ===
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/
frontend/.env*.local
frontend/next-env.d.ts
frontend/*.tsbuildinfo
frontend/.vercel

# === IDE / EDITORS ===
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*
*.code-workspace
.windsurf/
.windsurfrules

# === OS FILES ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# === TESTING / COVERAGE ===
coverage/
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml

# === SECURITY / CERTIFICATES ===
*.pem
*.cert
*.key
*.crt
*.csr
secrets/
private/

# === CELERY / BACKGROUND TASKS ===
celerybeat-schedule
celerybeat.pid
celeryev.pid
*.pid

# === TYPE CHECKING ===
.mypy_cache/
.dmypy.json
.pytype/

# === PROFILING ===
*.prof
.prof/

# === DEPLOYMENT PLATFORMS ===
.vercel
.netlify
.railway

# === DOCKER (if used) ===
docker-compose.override.yml
.dockerignore

# === LOGS ===
logs/
*.log
log/

# === TEMPORARY FILES ===
tmp/
temp/
*.tmp
*.temp
*.cache

# === RENDER / PRODUCTION (keep these) ===
!render.yaml
!Procfile
!runtime.txt